<?xml version="1.0" encoding="utf-8" ?>
<linker>
    <!-- Preserve the parameterless constructors of the ruleset types and mod properties as mod settings use reflection for parsing. -->

    <assembly fullname="osu.Game">
        <type fullname="osu.Game.Rulesets.Mods.*" preserve="all" />
    </assembly>
    <assembly fullname="osu.Game.Rulesets.Osu">
        <type fullname="osu.Game.Rulesets.Osu.OsuRuleset">
            <method signature="System.Void .ctor()" />
        </type>
        <type fullname="osu.Game.Rulesets.Osu.Mods.*" preserve="all" />
    </assembly>
    <assembly fullname="osu.Game.Rulesets.Taiko">
        <type fullname="osu.Game.Rulesets.Taiko.TaikoRuleset">
            <method signature="System.Void .ctor()" />
        </type>
        <type fullname="osu.Game.Rulesets.Taiko.Mods.*" preserve="all" />
    </assembly>
    <assembly fullname="osu.Game.Rulesets.Catch">
        <type fullname="osu.Game.Rulesets.Catch.CatchRuleset">
            <method signature="System.Void .ctor()" />
        </type>
        <type fullname="osu.Game.Rulesets.Catch.Mods.*" preserve="all" />
    </assembly>
    <assembly fullname="osu.Game.Rulesets.Mania">
        <type fullname="osu.Game.Rulesets.Mania.ManiaRuleset">
            <method signature="System.Void .ctor()" />
        </type>
        <type fullname="osu.Game.Rulesets.Mania.Mods.*" preserve="all" />
    </assembly>
</linker>