<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net9.0</TargetFramework>
        <PublishAot>true</PublishAot>
        <PublishTrimmed>true</PublishTrimmed>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
        <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="ppy.osu.Game" Version="2024.1115.3"/>
        <PackageReference Include="ppy.osu.Game.Rulesets.Catch" Version="2024.1115.3"/>
        <PackageReference Include="ppy.osu.Game.Rulesets.Mania" Version="2024.1115.3"/>
        <PackageReference Include="ppy.osu.Game.Rulesets.Osu" Version="2024.1115.3"/>
        <PackageReference Include="ppy.osu.Game.Rulesets.Taiko" Version="2024.1115.3"/>

        <PackageReference Include="ppy.osu.Game.Resources" Version="*">
            <ExcludeAssets>all</ExcludeAssets>
        </PackageReference>
    </ItemGroup>
</Project>
